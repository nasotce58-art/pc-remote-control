// Command: /pair (for manual pairing with device ID)
bot.command('pair', async (ctx) => {
  const userId = ctx.from?.id;
  const args = ctx.payload;

  console.log(`[/pair] User: ${userId}, Device ID: ${args}`);

  if (!args || args.length < 5) {
    await ctx.reply('❌ Неверный формат. Использование: /pair DEVICE_ID');
    return;
  }

  try {
    // Link user to device via Worker API
    const linkResponse = await axios.post(
      `${CLOUDFLARE_WORKER_URL}/api/user/${userId}/link/${args}`
    );

    if (linkResponse.data.ok) {
      console.log(`[/pair] Successfully linked user ${userId} to device ${args}`);
      
      await ctx.reply(
        `✅ ПК успешно подключён!\n\nDevice ID: ${args}`,
        {
          reply_markup: {
            inline_keyboard: [
              [{ text: '⚡ Вкл (Рестарт)', callback_data: 'restart_pc' }],
              [{ text: '� Выкл (Сон)', callback_data: 'sleep_pc' }],
              [{ text: '�📊 Статус ПК', callback_data: 'status_pc' }],
              [{ text: '🔌 Отключить ПК', callback_data: 'disconnect_pc' }]
            ]
          }
        }
      );
    } else {
      await ctx.reply(`❌ Ошибка: ${linkResponse.data.error}`);
    }
  } catch (error) {
    console.error('[/pair] Error:', error.message);
    
    if (error.response?.status === 404) {
      await ctx.reply('❌ Device ID не найден. Проверьте корректность ID.');
    } else {
      await ctx.reply('⚠️ Ошибка подключения к серверу. Попробуйте позже.');
    }
  }
});

// Function: Force Shutdown PC
async function handleForceShutdownPC(ctx, userId) {
  try {
    const responseData = await axios.get(
      `${CLOUDFLARE_WORKER_URL}/api/user/${userId}/device`,
      {
        headers: { Authorization: `Bearer ${BOT_TOKEN}` }
      }
    );

    const deviceId = responseData.data.deviceId;

    await axios.post(
      `${CLOUDFLARE_WORKER_URL}/api/commands/${deviceId}`,
      { command: 'force_shutdown', argument: null },
      {
        headers: { Authorization: `Bearer ${BOT_TOKEN}` }
      }
    );

    await ctx.reply('⏹️ ПК выключится принудительно через несколько секунд...');
  } catch (error) {
    console.error('Error sending force shutdown command:', error.message);
    await ctx.reply('❌ ПК не найден');
  }
}

