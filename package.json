{
  "name": "pc-remote-control",
  "version": "1.3.0",
  "description": "PC Remote Control Bot with Telegram and Cloudflare Worker",
  "main": "telegram-bot-node/bot.js",
  "scripts": {
    "start": "cd telegram-bot-node && node bot.js",
    "test": "cd telegram-bot-node && node bot-test.js",
    "worker:build": "cd cloudflare-worker && npm run build",
    "worker:deploy": "cd cloudflare-worker && wrangler publish",
    "dev": "concurrently \"npm run worker:dev\" \"npm run bot:dev\"",
    "bot:dev": "cd telegram-bot-node && node bot.js",
    "local-server": "node local-api-server.js",
    "local-all": "concurrently \"npm run local-server\" \"npm run bot:dev\" \"cd app/desktop && npm run dev\""
  },
  "keywords": [
    "telegram",
    "bot",
    "cloudflare",
    "worker",
    "pc-control",
    "remote"
  ],
  "author": "",
  "license": "MIT",
  "workspaces": [
    "telegram-bot-node",
    "cloudflare-worker"
  ],
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1"
  }
}
