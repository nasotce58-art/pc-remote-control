<Window x:Class="PCRemoteControl.Views.PairingConfirmationDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Device Pairing Confirmation"
        WindowStartupLocation="CenterOwner"
        Background="#0D1117"
        Foreground="#C9D1D9"
        Width="450"
        Height="280"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True">
    <Grid Background="#0D1117">
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">
            <!-- Header Icon -->
            <TextBlock Text="🔐" FontSize="48" TextAlignment="Center" Margin="0,0,0,20"/>
            
            <!-- Main Message -->
            <TextBlock 
                Text="Device Pairing Request"
                FontSize="20"
                FontWeight="Bold"
                Foreground="#C9D1D9"
                TextAlignment="Center"
                Margin="0,0,0,15"/>
            
            <!-- User Info -->
            <Border Background="#161B22" CornerRadius="6" Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Foreground="#8B949E" Text="User:" FontSize="12" Margin="0,0,0,3"/>
                    <TextBlock x:Name="UsernameTextBlock" Foreground="#C9D1D9" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    
                    <TextBlock Foreground="#8B949E" Text="Device ID:" FontSize="12" Margin="0,0,0,3"/>
                    <TextBlock x:Name="DeviceIdTextBlock" Foreground="#58A6FF" FontSize="12" FontFamily="Courier New" Margin="0,0,0,10"/>
                    
                    <TextBlock Foreground="#8B949E" Text="Valid for:" FontSize="12" Margin="0,0,0,3"/>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Foreground="#C9D1D9" FontSize="14" Margin="0,0,5,0">
                            <Run x:Name="CountdownRun" Text="30 seconds"/>
                        </TextBlock>
                        <ProgressBar 
                            x:Name="CountdownProgress"
                            Width="120" 
                            Height="6" 
                            Foreground="#238636"
                            Background="#21262D"
                            VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Warning -->
            <TextBlock 
                Text="⚠ Only confirm if YOU requested this pairing"
                Foreground="#F85149"
                FontSize="11"
                TextAlignment="Center"
                TextWrapping="Wrap"
                Margin="0,0,0,15"/>

            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,10">
                <Button 
                    x:Name="ConfirmButton"
                    Content="Allow"
                    Background="#238636"
                    Foreground="#FFFFFF"
                    FontWeight="Bold"
                    Padding="30,10"
                    Margin="0,0,10,0"
                    Click="ConfirmButton_Click"
                    Cursor="Hand"/>
                
                <Button 
                    x:Name="RejectButton"
                    Content="Deny"
                    Background="#DA3633"
                    Foreground="#FFFFFF"
                    FontWeight="Bold"
                    Padding="30,10"
                    Click="RejectButton_Click"
                    Cursor="Hand"/>
            </StackPanel>

            <!-- Status Text -->
            <TextBlock 
                x:Name="StatusTextBlock"
                Foreground="#8B949E"
                FontSize="11"
                TextAlignment="Center"
                Text="Waiting for your response..."
                Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</Window>
