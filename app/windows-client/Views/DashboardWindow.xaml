<Window x:Class="PCRemoteControl.DashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PC Remote Client"
        Height="800"
        Width="1200"
        Background="#0D1117"
        Foreground="#E6EDF3"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- Левая навигационная панель -->
        <Border Grid.Column="0" Background="#161B22" BorderThickness="0,0,1,0" BorderBrush="#30363D">
            <StackPanel Orientation="Vertical" Margin="0">
                <!-- Logo -->
                <Border Background="#0D47A1" Padding="15" Height="70" VerticalAlignment="Top">
                    <TextBlock Text="🖥️ PC Remote" FontSize="16" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </Border>

                <!-- Navigation Items -->
                <ListBox x:Name="NavigationMenu" Background="Transparent" BorderThickness="0" 
                        Foreground="#E6EDF3" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBoxItem x:Name="NavDashboard" Height="45" Selected="NavDashboard_Selected" 
                                Background="Transparent" Foreground="#58A6FF" Padding="20,10">
                        <TextBlock Text="📊 Dashboard" VerticalAlignment="Center"/>
                    </ListBoxItem>
                    <ListBoxItem x:Name="NavPower" Height="45" Selected="NavPower_Selected"
                                Background="Transparent" Foreground="#E6EDF3" Padding="20,10">
                        <TextBlock Text="⚡ Питание" VerticalAlignment="Center"/>
                    </ListBoxItem>
                    <ListBoxItem x:Name="NavMonitoring" Height="45" Selected="NavMonitoring_Selected"
                                Background="Transparent" Foreground="#E6EDF3" Padding="20,10">
                        <TextBlock Text="📊 Мониторинг" VerticalAlignment="Center"/>
                    </ListBoxItem>
                    <ListBoxItem x:Name="NavFiles" Height="45" Selected="NavFiles_Selected"
                                Background="Transparent" Foreground="#E6EDF3" Padding="20,10">
                        <TextBlock Text="📁 Файлы" VerticalAlignment="Center"/>
                    </ListBoxItem>
                    <ListBoxItem x:Name="NavControl" Height="45" Selected="NavControl_Selected"
                                Background="Transparent" Foreground="#E6EDF3" Padding="20,10">
                        <TextBlock Text="⌨️ Управление" VerticalAlignment="Center"/>
                    </ListBoxItem>
                    <ListBoxItem x:Name="NavSettings" Height="45" Selected="NavSettings_Selected"
                                Background="Transparent" Foreground="#E6EDF3" Padding="20,10">
                        <TextBlock Text="⚙️ Настройки" VerticalAlignment="Center"/>
                    </ListBoxItem>
                    <ListBoxItem x:Name="NavLogs" Height="45" Selected="NavLogs_Selected"
                                Background="Transparent" Foreground="#E6EDF3" Padding="20,10">
                        <TextBlock Text="📜 Логи" VerticalAlignment="Center"/>
                    </ListBoxItem>
                </ListBox>
            </StackPanel>
        </Border>

        <!-- Основное содержимое -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="1*"/>
            </Grid.RowDefinitions>

            <!-- Верхняя панель -->
            <Border Grid.Row="0" Background="#161B22" BorderThickness="0,0,0,1" BorderBrush="#30363D">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0" HorizontalAlignment="Right">
                        <TextBlock x:Name="StatusIndicator" Text="🟢 Online" FontSize="14" FontWeight="Bold" 
                                  Foreground="#3FB950" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <TextBlock x:Name="CloudflareStatus" Text="☁️ Cloudflare: Connected" FontSize="12" 
                                  Foreground="#58A6FF" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <Button x:Name="LanguageButton" Grid.Column="1" Content="RU" Width="45" Height="40" 
                            Background="#0D47A1" Foreground="White" FontWeight="Bold" Margin="0,0,20,0"
                            Click="LanguageButton_Click" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Основное содержимое (контент разных страниц) -->
            <Border Grid.Row="1" Background="#0D1117" Padding="25">
                <StackPanel x:Name="MainContentArea" Orientation="Vertical">
                    <!-- Здесь будет загружаться контент каждой страницы -->
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
