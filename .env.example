# PC Remote Control - Environment Configuration
# Скопируйте этот файл в .env и заполните значения

# ==================== TELEGRAM BOT ====================
# Получите токен у @BotFather в Telegram
BOT_TOKEN=your_bot_token_here

# Получите ваш Chat ID у @userinfobot
ADMIN_CHAT_ID=your_chat_id_here

# ==================== CLOUDFLARE WORKER ====================
# URL вашего Cloudflare Worker (после деплоя)
CLOUDFLARE_WORKER_URL=https://pc-remote-control.your-username.workers.dev

# ==================== ИНСТРУКЦИИ ====================
# 1. Скопируйте этот файл: copy .env.example .env
# 2. Получите токен бота: https://t.me/BotFather
# 3. Получите ваш Chat ID: https://t.me/userinfobot
# 4. Разверните Cloudflare Worker (см. cloudflare-worker/DEPLOYMENT.md)
# 5. Вставьте URL Worker в CLOUDFLARE_WORKER_URL
